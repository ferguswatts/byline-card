{
  "nzherald.co.nz": {
    "selectors": {
      "byline": ".author-name, .article__author-name, [class*='author'] a"
    }
  },
  "stuff.co.nz": {
    "selectors": {
      "byline": ".author-name, .sics-component__byline a, a[href*='/authors/'], [class*='author']"
    }
  },
  "thepost.co.nz": {
    "selectors": {
      "byline": ".author-name, .sics-component__byline a, [class*='author']"
    }
  },
  "rnz.co.nz": {
    "selectors": {
      "byline": ".author, .article__author, [class*='author']"
    }
  },
  "1news.co.nz": {
    "selectors": {
